# ============================================
# ContainerLab GUI - 環境変数
# ============================================
# cp .env.example .env して値を入力
# ⚠️ .env はGitにコミットしないこと

# ---- Aruba AOS-CX SSH認証（vrnetlabデフォルト） ----
AOSCX_SSH_USER=admin
AOSCX_SSH_PASS=admin

# ---- Juniper vJunos-Switch SSH認証（vrnetlabデフォルト） ----
VJUNOS_SSH_USER=admin
VJUNOS_SSH_PASS=admin@123
